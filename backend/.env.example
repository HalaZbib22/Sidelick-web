# Copy to .env and fill in
PORT=4000
DATABASE_URL=postgres://USER:PASS@localhost:5432/sidelick
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Comma-separated origins allowed to call the API (the frontend)
CORS_ORIGIN=http://localhost:3000
# Used to build password-reset links
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
# Web Push (closed-app notifications). Generate once:
#   npx web-push generate-vapid-keys
# Leave blank to disable push (the app still works via in-app socket notifications).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@sidelick.app

# Payments (Stripe). Leave STRIPE_SECRET_KEY blank to disable payments entirely
# (bookings still work; the pay UI is hidden and walks can start without a hold).
# Get keys from the Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
# Safe to expose to the browser; the frontend fetches it from /api/payments/config.
STRIPE_PUBLISHABLE_KEY=
# From `stripe listen` (dev) or the webhook endpoint's signing secret (prod).
# Endpoint: POST /api/payments/webhook
STRIPE_WEBHOOK_SECRET=
